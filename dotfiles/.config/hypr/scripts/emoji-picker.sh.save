🔰 Japanese Symbol for Beginner"

# Show emoji picker in rofi
selected=$(echo "$emoji_list" | rofi -dmenu -i -p "Emoji" -theme "$rofi_theme")

# Extract just the emoji (first character)
if [ -n "$selected" ]; then
    emoji=$(echo "$selected" | awk '{print $1}')
    # Copy to clipboard using wl-copy (Wayland)
    echo -n "$emoji" | wl-copy
    # Send notification
    notify-send "Emoji Copied" "$emoji copied to clipboard"
fi

exit 0
