#!/usr/bin/env bash
# Working Cliphist Script with Image Previews and Clear Button
# Sends SwayNC notifications for image clipboard items
# Place in ~/.config/rofi/scripts/cliphist-rofi

tmp_dir="/tmp/cliphist"
rofi_theme="~/.config/rofi/launchers/type-1/style-5.rasi"

# Clean up and create temp directory
rm -rf "$tmp_dir" && mkdir -p "$tmp_dir"

# Handle rofi selection
if [ -n "$1" ]; then
    # Check if it's the clear option
    if echo "$1" | grep -q "CLEAR_ALL"; then
        if echo -e "Yes, delete all history\nNo, cancel" | rofi -dmenu \
            -theme "$rofi_theme" \
            -p "Are you sure?" \
            -mesg "This will permanently delete all clipboard history" \
            -theme-str 'window { width: 500px; height: 220px; }' \
            -theme-str 'listview { lines: 2; }' | grep -q "Yes"; then
            cliphist wipe
            swaync notify "Clipboard Manager" "Clipboard history cleared!"
        else
            swaync notify "Clipboard Manager" "Clear cancelled"
        fi
        exit
    fi

    # Get the ID from the beginning of the line and decode it
    id=$(echo "$1" | awk '{print $1}')
    cliphist decode "$id" | cliphist store

    # Get the content for notification
    content=$(echo "$1" | cut -d$'\t' -f2-)

    # Only send SwayNC notification if it is an image
    if echo "$content" | grep -q "Image"; then
        swaync notify "Clipboard Manager" "Image copied to clipboard"
    fi
    exit
fi

# Create menu file
menu_file="/tmp/cliphist_menu.txt"
rm -f "$menu_file"

# Add clear option at the top
echo -e "CLEAR_ALL\t0. Clear History (Delete All)" >> "$menu_file"

# Get cliphist output and process items
counter=0
while IFS=$'\t' read -r id content; do
    counter=$((counter + 1))
    
    # Skip meta entries
    if echo "$content" | grep -q "<meta http-equiv="; then
        continue
    fi
    
    # Check if it's an image
    if echo "$content" | grep -q "binary.*\.(jpg\|jpeg\|png\|bmp\|gif\|webp)"; then
        ext=$(echo "$content" | grep -oE '\.(jpg|jpeg|png|bmp|gif|webp)' | head -1)
        [ -z "$ext" ] && ext=".png"
        img_file="$tmp_dir/img_${id}${ext}"
        cliphist decode "$id" > "$img_file" 2>/dev/null
        display_text="${counter}. Image${ext}"
        echo -e "${id}\t${display_text}\0icon\x1f${img_file}" >> "$menu_file"
    else
        display_text=$(echo "$content" | tr '\n\r' ' ' | sed 's/  */ /g')
        [ ${#display_text} -gt 80 ] && display_text="${display_text:0:77}..."
        echo -e "${id}\t${counter}. ${display_text}" >> "$menu_file"
    fi
done < <(cliphist list)

# Run rofi
if [ -f "$menu_file" ]; then
    selected=$(cat "$menu_file" | rofi -dmenu \
        -theme "$rofi_theme" \
        -p "Clipboard Manager" \
        -markup-rows \
        -show-icons \
        -icon-theme "Papirus" \
        -eh 6 \
        -scroll-method 0 \
        -format "s" \
        -theme-str 'element-icon { size: 96px; }' \
        -theme-str 'listview { lines: 20; }' \
        -theme-str 'window { width: 800px; height: 1000px; }' \
        -mesg "Select item to copy, or choose 'Clear History' to delete all")
    
    if [ -n "$selected" ]; then
        exec "$0" "$selected"
    fi
fi

# Cleanup
rm -f "$menu_file"
rm -rf "$tmp_dir"

