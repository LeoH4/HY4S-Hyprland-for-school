#!/usr/bin/env bash

# Debug script to test image extraction
# Place in ~/.config/rofi/scripts/debug-cliphist

tmp_dir="/tmp/cliphist_debug"
rm -rf "$tmp_dir" && mkdir -p "$tmp_dir"

echo "=== Debug Cliphist Image Extraction ==="
echo "1. Testing cliphist list output:"
echo "-----------------------------------"

# Show raw cliphist output
cliphist list | head -5

echo -e "\n2. Looking for binary entries:"
echo "------------------------------"

# Find binary entries
cliphist list | grep -E "binary.*(jpg|jpeg|png|bmp|gif|webp)" | head -3

echo -e "\n3. Testing image extraction:"
echo "----------------------------"

# Test extracting first image
first_image_id=$(cliphist list | grep -E "binary.*(jpg|jpeg|png|bmp|gif|webp)" | head -1 | cut -d$'\t' -f1)

if [[ -n "$first_image_id" ]]; then
    echo "Found image ID: $first_image_id"
    
    # Try to extract it
    echo "Extracting to: $tmp_dir/test_image.jpg"
    cliphist decode "$first_image_id" > "$tmp_dir/test_image.jpg"
    
    # Check if file was created and has content
    if [[ -f "$tmp_dir/test_image.jpg" ]]; then
        size=$(du -h "$tmp_dir/test_image.jpg" | cut -f1)
        echo "✓ Image extracted successfully! Size: $size"
        echo "File path: $tmp_dir/test_image.jpg"
        
        # Try to identify the file type
        if command -v file &> /dev/null; then
            file_type=$(file "$tmp_dir/test_image.jpg")
            echo "File type: $file_type"
        fi
        
        # Test rofi with this specific image
        echo -e "\n4. Testing rofi with extracted image:"
        echo "------------------------------------"
        echo -e "Test Item 1\nImage Test\0icon\x1f$tmp_dir/test_image.jpg\nTest Item 2" | \
        rofi -dmenu -markup-rows -show-icons -p "Test Image Preview"
        
    else
        echo "✗ Failed to extract image"
    fi
else
    echo "No images found in clipboard history"
    echo "Try copying an image first, then run this script again"
fi

echo -e "\n5. Checking rofi icon support:"
echo "------------------------------"
rofi -help | grep -i icon
echo "Temp directory contents:"
ls -la "$tmp_dir/"
